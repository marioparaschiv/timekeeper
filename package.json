{
	"name": "timekeeper",
	"main": "src/index.ts",
	"private": true,
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"deploy": "bun src/deploy.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"lint": "oxlint --type-aware --config .oxlintrc.json --fix-dangerously src",
		"fmt": "oxfmt --config .oxfmtrc.json src"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@typescript/native-preview": "^7.0.0-dev.20260222.1",
		"better-sqlite3": "12.6.2",
		"drizzle-kit": "0.31.9",
		"eslint-plugin-perfectionist": "^5.6.0",
		"oxfmt": "^0.34.0",
		"oxlint": "^1.49.0",
		"oxlint-tsgolint": "^0.14.2"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"discord.js": "14.25.1",
		"drizzle-orm": "0.45.1"
	}
}