BOT_TOKEN=
CLIENT_ID=

# Only used when NODE_ENV=development, where commands register to this one
# guild for instant updates. Production registers globally.
GUILD_ID=
HOURLY_RATE=
SOLANA_ADDRESS=
OWNER_ID=

# Optional, defaults to timekeeper.db
DATABASE_PATH=

# Defaults to development, which registers commands to GUILD_ID only. Set this
# to production in deployment so commands register globally across every guild.
NODE_ENV=
